# ---------------------------------------------------------------------------
# Fichier d'exemple pour les variables d'environnement (api_cantine)
# Copier vers .env et adapter les valeurs :  cp .env.example .env
# Ne jamais committer .env (secrets).
# ---------------------------------------------------------------------------

# --- Django ---
# Clé secrète : générer une valeur unique (ex. python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())")
SECRET_KEY=changez-moi-vers-une-cle-secrete-longue-et-aleatoire

# True en développement uniquement
DEBUG=True

# Hôtes autorisés, séparés par des virgules (sans espaces autour du =)
# Exemple local : localhost,127.0.0.1
# Production : votredomaine.com,www.votredomaine.com
ALLOWED_HOSTS=localhost,127.0.0.1

# --- Base de données MySQL / MariaDB ---
# Option A — variables séparées (utilisées si DATABASE_URL est vide) :
DATABASE_NAME=bdd_cantine
DATABASE_USER=root
DATABASE_PASSWORD=
DATABASE_HOST=127.0.0.1
DATABASE_PORT=3306

# Option B — une seule URL (prioritaire sur l’option A si renseignée) :
# Exemple : mysql://USER:MOTDEPASSE@HOST:3306/NOM_BDD
# DATABASE_URL=

# Persistance des connexions DB (secondes). 0 = nouvelle connexion à chaque requête (défaut dev).
# DATABASE_CONN_MAX_AGE=0

# Chemin vers le certificat CA pour MySQL en SSL (optionnel, laisser vide en local)
# DATABASE_SSL_CA=

# --- Chatbot Gemini (script chatbot.py) ---
# Clé API Google Cloud / Gemini — ne jamais committer la valeur réelle
GEMINI_API_KEY=

# --- Connexion Google OAuth (SaaS uhakikaapp.store) ---
# Client ID OAuth 2.0 (Console Google Cloud → Identifiants → ID client Web).
# Plusieurs clients : GOOGLE_OAUTH_CLIENT_ID=web-id.apps.googleusercontent.com,android-id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_ID=

# --- Contrôle licence SaaS (True = bloquer écritures si abonnement expiré) ---
LICENCE_CONTROLE_ACTIF=True

# --- Paiements en ligne SaaS ---
PAIEMENT_GATEWAY_SANDBOX=True
PAIEMENT_RETURN_BASE_URL=https://uhakikaapp.store
PAIEMENT_WEBHOOK_BASE_URL=http://127.0.0.1:8000

MAISHA_PAY_API_KEY=
MAISHA_PAY_WEBHOOK_SECRET=
FLEXPAY_API_KEY=
FLEXPAY_WEBHOOK_SECRET=
SERDI_PAY_API_KEY=
SERDI_PAY_WEBHOOK_SECRET=
